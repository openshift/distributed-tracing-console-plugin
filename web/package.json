{
  "name": "distributed-tracing-console-plugin",
  "version": "1.0.0",
  "private": true,
  "repository": "git@github.com:openshift/distributed-tracing-console-plugin.git",
  "license": "Apache-2.0",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && NODE_ENV=production npm run webpack",
    "build-dev": "npm run clean && npm run webpack",
    "start": "npm run webpack serve -- --progress",
    "start-console": "./start-console.sh",
    "i18n": "i18n-scripts/build-i18n.sh && node i18n-scripts/set-english-defaults.js",
    "lint": "eslint src --fix && stylelint 'src/**/*.css' --allow-empty-input --fix",
    "type-check": "tsc --noEmit",
    "test:unit": "TZ=UTC jest --config jest.config.js",
    "test-cypress": "cd integration-tests s && cypress open --env openshift=true",
    "test-cypress-headless": "cd integration-tests && node --max-old-space-size=4096 ../node_modules/.bin/cypress run --env openshift=true --browser ${BRIDGE_E2E_BROWSER_NAME:=chrome}",
    "cypress-merge": "mochawesome-merge ./integration-tests/screenshots/cypress_report*.json > ./integration-tests/screenshots/cypress.json",
    "cypress-generate": "marge -o ./integration-tests/screenshots/ -f cypress-report -t 'OpenShift Console Plugin Template Cypress Test Results' -p 'OpenShift Cypress Plugin Template Test Results' --showPassed false --assetsDir ./integration-tests/screenshots/cypress/assets ./integration-tests/screenshots/cypress.json",
    "cypress-postreport": "npm run cypress-merge && npm run cypress-generate",
    "webpack": "node -r ts-node/register ./node_modules/.bin/webpack"
  },
  "devDependencies": {
    "@cypress/webpack-preprocessor": "^6.0.2",
    "@openshift-console/dynamic-plugin-sdk": "^4.22.0-prerelease.2",
    "@openshift-console/dynamic-plugin-sdk-webpack": "^4.22.0-prerelease.2",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.19.15",
    "@types/react": "^18.3.1",
    "css-loader": "^6.7.1",
    "cypress": "^14.2.1",
    "cypress-multi-reporters": "^1.6.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "i18next-parser": "^9.3.0",
    "js-yaml": "^4.1.0",
    "mocha-junit-reporter": "^2.2.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "pluralize": "^8.0.0",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "~16.5.8",
    "style-loader": "^3.3.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "ts-jest": "^29.4.4",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.32.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "consolePlugin": {
    "name": "distributed-tracing-console-plugin",
    "version": "0.0.1",
    "displayName": "Distributed Tracing Plugin",
    "description": "This plugin adds a distributed tracing UI to the Openshift console.",
    "exposedModules": {
      "TracesPage": "./pages/TracesPage/TracesPage",
      "TraceDetailPage": "./pages/TraceDetailPage/TraceDetailPage"
    },
    "dependencies": {
      "@console/pluginAPI": "*"
    }
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@grafana/lezer-traceql": "^0.0.25",
    "@hookform/resolvers": "^3.10.0",
    "@patternfly/react-charts": "^8.4.1",
    "@patternfly/react-core": "^6.4.1",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-templates": "^6.4.1",
    "@perses-dev/components": "^0.53.0",
    "@perses-dev/core": "0.53.0",
    "@perses-dev/dashboards": "^0.53.0",
    "@perses-dev/plugin-system": "^0.53.0",
    "@perses-dev/scatter-chart-plugin": "^0.10.0",
    "@perses-dev/tempo-plugin": "^0.57.0",
    "@perses-dev/trace-table-plugin": "^0.10.0",
    "@perses-dev/tracing-gantt-chart-plugin": "^0.12.0",
    "copy-webpack-plugin": "^14.0.0",
    "i18next": "^25.10.5",
    "i18next-http-backend": "^3.0.2",
    "lodash-es": "^4.17.21",
    "react-router": "^7.13.2",
    "use-query-params": "^2.2.2",
    "victory": "^37.3.6"
  },
  "peerDependencies": {
    "react-router-dom": "^7"
  },
  "overrides": {
    "@perses-dev/core": "0.53.0",
    "echarts": "^5.6.0"
  }
}
